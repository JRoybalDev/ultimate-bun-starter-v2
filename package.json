{
  "name": "ultimate-bun-starter-v2",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev:backend": "bun run src/server.ts",
    "dev:frontend": "bun run vite",
    "dev": "bun run concurrently 'bun run dev:backend' 'bun run dev:frontend'",
    "build": "bun run tsc && bun run vite build",
    "preview": "bun run vite preview",
    "db:setup": "bun run src/db/setup.ts",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:seed": "bun run src/db/seed.ts",
    "format": "bun run prettier --write .",
    "lint": "bun run eslint . --ext .ts,.tsx",
    "lint:fix": "bun run eslint . --ext .ts,.tsx --fix"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.38.0",
    "hono": "^4.12.12",
    "jose": "^6.2.2",
    "lucide-react": "^1.8.0",
    "pg": "^8.11.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "daisyui": "^5.5.19",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "postcss": "^8.5.9",
    "prettier": "^3.0.0",
    "react-router-dom": "^6.17.0",
    "tailwindcss": "3.4.4",
    "typescript": "^5.6.0",
    "vite": "^8.0.8"
  }
}
