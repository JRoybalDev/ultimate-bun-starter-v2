# Choose one database mode:
# SQLite is easiest for local development.
SQLITE_FILE=./dev.db

# Uncomment and set a Postgres connection string for production.
# DATABASE_URL=postgres://user:pass@localhost:5432/mydb

JWT_SECRET=replace-with-a-secret

# OAuth providers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/oauth/github/callback
